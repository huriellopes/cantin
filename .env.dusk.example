# Laravel Dusk (testes de browser) — copie para .env.dusk.local (gitignored).
#
# Como rodar:
#   1. cp .env .env.dusk.local
#   2. ajuste as duas chaves abaixo no .env.dusk.local
#   3. suba o browser:  docker compose --profile dusk up -d selenium
#   4. rode:            ./vendor/bin/sail dusk
#
# APP_URL precisa ser alcançável pelo browser do Selenium na rede interna
# (use o hostname do serviço da app, não localhost).
APP_URL=http://laravel.test

# Endpoint WebDriver do serviço Selenium (docker-compose, profile "dusk").
DUSK_DRIVER_URL=http://selenium:4444/wd/hub
